rules_version = '2';

// Aura security rules. Heart writes are mentor-only. Aura: mentors give ±10
// freely; non-mentors are capped at ±1 and at most 2 awards per UTC day. Users
// can only edit their own non-privileged profile fields. Deploy with:
//   firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }

    function roleOf(id) {
      return get(/databases/$(database)/documents/users/$(id)).data.role;
    }
    // "canAward" mirrors the app: anyone who isn't an intern.
    function canAward(id) {
      return roleOf(id) in ['mentor', 'fullTime', 'admin'];
    }
    function changed() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }
    // Daily aura quota for non-mentors. `today()` is a UTC yyyymmdd int that
    // matches DateUtils.currentDayKeyUtc on the client.
    function today() {
      return request.time.year() * 10000
        + request.time.month() * 100
        + request.time.day();
    }
    // Awards a giver has already given today (0 on a new day / no counter yet).
    function usedToday(id) {
      let d = get(/databases/$(database)/documents/users/$(id)).data;
      return d.get('awardDay', 0) == today() ? d.get('awardCount', 0) : 0;
    }
    // Prior-day-aware count for THIS user's own doc (in a users update).
    function priorCount() {
      return resource.data.get('awardDay', 0) == today()
        ? resource.data.get('awardCount', 0) : 0;
    }
    function auraDailyLimit() { return 2; }

    match /users/{userId} {
      allow read: if isSignedIn();

      // Self-registration only; can't self-assign a privileged role or stats.
      allow create: if isSignedIn()
        && userId == uid()
        && request.resource.data.role == 'intern'
        && request.resource.data.currentWeekAura == 0
        && request.resource.data.totalAura == 0;

      allow update: if isSignedIn() && (
        // Owner edits non-privileged profile fields (no role/position/aura/
        // hearts — position is assigned, not self-editable).
        (userId == uid() && changed().hasOnly(
          ['displayName', 'photoURL', 'fcmTokens',
           'metadata', 'lastRouletteDate'])) ||

        // A mentor changes someone's hearts by ±1, kept within 0..8.
        (canAward(uid())
          && changed().hasOnly(['hearts'])
          && request.resource.data.hearts is int
          && request.resource.data.hearts >= 0
          && request.resource.data.hearts <= 8
          && request.resource.data.hearts - resource.data.hearts >= -1
          && request.resource.data.hearts - resource.data.hearts <= 1) ||

        // Any signed-in user awards aura (both counters move together).
        (changed().hasOnly(['currentWeekAura', 'totalAura'])) ||

        // Non-mentor giver advances their own daily quota counter: must be
        // today's key and exactly prior+1, never above the daily limit. The
        // day key is server-derived so it can't be faked to reset early.
        (userId == uid()
          && !canAward(uid())
          && changed().hasOnly(['awardDay', 'awardCount'])
          && request.resource.data.awardDay == today()
          && request.resource.data.awardCount == priorCount() + 1
          && request.resource.data.awardCount <= auraDailyLimit())
      );

      allow delete: if false;
    }

    // Heart changes (append-only). Mentor-only, ±1, comment required to remove.
    match /hearts_transactions/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.fromUserId == uid()
        && canAward(uid())
        && request.resource.data.toUserId != uid()
        && request.resource.data.delta in [1, -1]
        && (request.resource.data.delta == 1
            || request.resource.data.comment.size() > 0);
      allow update, delete: if false;
    }

    // Aura awards (append-only). Mentors: ±10, unlimited. Non-mentors: ±1 and
    // at most `auraDailyLimit()` per UTC day (counter on users, bumped in the
    // same transaction — see the users update rule above).
    match /aura_transactions/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.fromUserId == uid()
        && request.resource.data.toUserId != uid()
        && request.resource.data.points is int
        && (
          canAward(uid())
            ? (request.resource.data.points >= -10
               && request.resource.data.points <= 10)
            : (request.resource.data.points >= -1
               && request.resource.data.points <= 1
               && usedToday(uid()) < auraDailyLimit())
        );
      allow update, delete: if false;
    }

    match /roulette_history/{userId}/spins/{spin} {
      allow read, create: if isSignedIn() && userId == uid();
    }

    match /attendance/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.timestamp is timestamp;
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'checkOutTimestamp', 'checkOutNote',
          'lunchStart', 'lunchEnd', 'lunchNote'
        ]);
      allow delete: if false;
    }
  }
}
